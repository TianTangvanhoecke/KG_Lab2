@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <https://TianTangvanhoecke.github.io/KG_Lab2/vocab.ttl#> .

:Person a rdfs:Class ;
    rdfs:label "Person"@en ;
    rdfs:comment "A human being."@en .

:hasFullName a rdf:Property ;
    rdfs:label "has full name"@en ;
    rdfs:comment "The complete name of a person."@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasNationality a rdf:Property ;
    rdfs:label "has nationality"@en ;
    rdfs:comment "The nationality of a person"@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasAge a rdf:Property ;
    rdfs:label "has age"@en ;
    rdfs:comment "Age of a person"@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:integer .

:knows a rdf:Property ;
    rdfs:label "knows"@en ;
    rdfs:comment "A relationship between two people."@en ;
    rdfs:domain :Person ;
    rdfs:range :Person .

:Student a rdfs:Class ;
    rdfs:label "Student"@en ;
    rdfs:comment "A person who is enrolled in an educational institution."@en ;
    rdfs:subClassOf :Person .  

:hasStudentID a rdf:Property ;
    rdfs:label "has student ID"@en ;
    rdfs:comment "Assigns a unique identifier to a student within an educational institution."@en ;
    rdfs:domain :Student ; 
    rdfs:range xsd:string . 

:Course a rdfs:Class ;
    rdfs:label "Course" ;
    rdfs:comment "A course offered at an educational institution." .

:enrolledIn a rdf:Property ;
    rdfs:label "enrolled in" ;
    rdfs:comment "Relates a student to a course they are enrolled in." ;
    rdfs:domain :Student ;
    rdfs:range :Course .
